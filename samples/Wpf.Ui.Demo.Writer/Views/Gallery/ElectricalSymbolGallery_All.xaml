            <StackPanel Margin="10" Width="100" Height="100">
                <Viewbox Width="80" Height="80">
                    <Canvas Width="40" Height="40">
                        <Path Stroke="Black" StrokeThickness="2" Data="M20,20 m-10,0 a10,10 0 1,0 20,0 a10,10 0 1,0 -20,0 M20,10 L20,20 L25,25" />
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Ammeter" FontSize="10" TextAlignment="Center" TextWrapping="Wrap"/>
