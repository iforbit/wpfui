<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Electrical Symbol Gallery - Full" Width="1200" Height="800">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <WrapPanel Margin="20">

            <StackPanel Margin="10" Width="100" Height="100">
                <Viewbox Width="80" Height="80">
                    <Canvas Width="40" Height="40">
                        <Path Stroke="Black" StrokeThickness="2" Data="M5,20 L15,20 M15,15 L25,25 M15,25 L25,15 M25,20 L35,20" />
                    </Canvas>
                </Viewbox>
                <TextBlock Text="Fuse" FontSize="10" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Margin="10" Width="100" Height="100">
                <Viewbox Width="80" Height="80">
