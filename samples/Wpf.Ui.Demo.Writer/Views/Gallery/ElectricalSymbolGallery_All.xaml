                </Viewbox>
                <TextBlock Text="CircuitBreaker" FontSize="10" TextAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Margin="10" Width="100" Height="100">
                <Viewbox Width="80" Height="80">
                    <Canvas Width="40" Height="40">
