<Page x:Name="writeBoardPage"
      x:Class="Wpf.Ui.Demo.Writer.Views.Pages.WriteBoardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:Wpf.Ui.Demo.Writer.Converter"
      xmlns:local="clr-namespace:Wpf.Ui.Demo.Writer.Views.Pages"
      xmlns:sharedMemory="clr-namespace:Wpf.Ui.Demo.Writer.SharedMemory"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Wpf.Ui.Demo.Writer.ViewModels"
      Title="Signal Generator WriteBoard"
      d:DataContext="{d:DesignInstance vm:WriteBoardViewModel,
                                       IsDesignTimeCreatable=True}"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToTextConverter x:Key="BooleanToTextConverter" />
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <ui:CardControl Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Margin="0,0,0,10" FontSize="24" FontWeight="Bold"
                           Text="Signal Generator Control" />
                <TextBlock FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           Text="Generate signals and write to shared memory for real-time graph visualization" />
            </StackPanel>
        </ui:CardControl>

        <!--  Control Panel  -->
        <ui:CardControl Grid.Row="1" Margin="0,0,0,20">
            <ui:CardControl.Header>
                <!--  Control Buttons  -->
                <StackPanel Margin="0,0,10,0" HorizontalAlignment="Left">
                    <ui:Button Margin="0,0,0,10" HorizontalAlignment="Stretch" Appearance="Primary"
                               Command="{Binding StartCommand}"
                               Content="Start"
                               Icon="{ui:SymbolIcon Play24}" />

                    <ui:Button Margin="0,0,0,10" HorizontalAlignment="Stretch" Appearance="Secondary"
                               Command="{Binding StopCommand}"
                               Content="Stop"
                               Icon="{ui:SymbolIcon Stop24}" />

                    <ui:Button HorizontalAlignment="Stretch" Appearance="Caution"
                               Command="{Binding ResetCommand}"
                               Content="Reset"
                               Icon="{ui:SymbolIcon ArrowReset24}" />
                </StackPanel>
            </ui:CardControl.Header>
            <StackPanel>
                <TextBlock Margin="0,0,0,15" FontSize="18" FontWeight="SemiBold"
                           Text="Generation Control" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Parameters Column 1  -->
                    <StackPanel Grid.Column="0" Width="200" Margin="10,0">
                        <TextBlock Margin="0,0,0,5" Text="Update Rate (Hz)"
                                   ToolTip="초당 데이터 전송 횟수. 60Hz = 1초에 60번 업데이트" />
                        <ui:NumberBox Margin="0,0,0,15" Maximum="1000" Minimum="1"
                                      SpinButtonPlacementMode="Inline"
                                      ToolTip="높을수록 실시간성 향상, CPU 사용량 증가"
                                      Value="{Binding UpdateRate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,0,5" Text="Channel Count"
                                   ToolTip="동시에 표시할 채널(신호선) 개수" />
                        <ui:NumberBox Margin="0,0,0,15" Maximum="10" Minimum="1"
                                      SpinButtonPlacementMode="Inline"
                                      ToolTip="최대 10개 채널까지 지원"
                                      Value="{Binding ChannelCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <!--  Parameters Column 2  -->
                    <StackPanel Grid.Column="1" Width="200" Margin="10,0,0,0">
                        <TextBlock Margin="0,0,0,5" Text="Points Per Update"
                                   ToolTip="한 번 업데이트 시 전송할 데이터 포인트 개수" />
                        <ui:NumberBox Margin="0,0,0,15" Maximum="50000" Minimum="10"
                                      SpinButtonPlacementMode="Inline"
                                      ToolTip="적을수록 촘촘한 파형, 많을수록 부드러운 스크롤&#x0a;샘플링레이트 = UpdateRate × Points"
                                      Value="{Binding PointsPerUpdate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,0,0,5" Text="Status" />
                        <ui:Badge Padding="10,5"
                                  Appearance="{Binding IsRunning, Converter={StaticResource BooleanToTextConverter}, ConverterParameter='Success|Secondary'}"
                                  Content="{Binding IsRunning, Converter={StaticResource BooleanToTextConverter}, ConverterParameter='Running|Stopped'}"
                                  FontSize="14" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ui:CardControl>

        <!--  Channel Configuration Header  -->
        <ui:CardControl Grid.Row="2" Margin="0,0,0,10" VerticalAlignment="Center">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Channel Configuration" />
        </ui:CardControl>

        <!--  Channel List  -->
        <Border Grid.Row="3" Cursor="">
            <ScrollViewer MaxHeight="600" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Channels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ChannelConfig}">
                            <ui:CardExpander Margin="0,0,0,10" ContentPadding="15"
                                             Header="{Binding Name}">
                                <ui:CardExpander.Icon>
                                    <ui:SymbolIcon Symbol="DataTrending24" />
                                </ui:CardExpander.Icon>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!--  Row 1  -->
                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Margin="0,0,0,5" Text="Signal Type"
                                                   ToolTip="파형 종류 선택" />
                                        <ComboBox HorizontalAlignment="Stretch" SelectedItem="{Binding Type, Mode=TwoWay}"
                                                  ToolTip="Sine: 사인파, Square: 사각파, Triangle: 삼각파&#x0a;Sawtooth: 톱니파, Noise: 랜덤 노이즈">
                                            <sharedMemory:SignalType>Sine</sharedMemory:SignalType>
                                            <sharedMemory:SignalType>Cosine</sharedMemory:SignalType>
                                            <sharedMemory:SignalType>Square</sharedMemory:SignalType>
                                            <sharedMemory:SignalType>Triangle</sharedMemory:SignalType>
                                            <sharedMemory:SignalType>Sawtooth</sharedMemory:SignalType>
                                            <sharedMemory:SignalType>Noise</sharedMemory:SignalType>
                                        </ComboBox>
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0">
                                        <TextBlock Margin="0,0,0,5" Text="Frequency (Hz)"
                                                   ToolTip="신호의 주파수 (초당 반복 횟수)" />
                                        <ui:NumberBox Maximum="100" Minimum="0.1" SpinButtonPlacementMode="Inline"
                                                      ToolTip="높을수록 빠르게 진동. 예: 10Hz = 1초에 10번 반복"
                                                      Value="{Binding Frequency, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="10,0,0,0">
                                        <TextBlock Margin="0,0,0,5" Text="Amplitude"
                                                   ToolTip="신호의 진폭 (Y축 최대 높이)" />
                                        <ui:NumberBox Maximum="10" Minimum="0" SpinButtonPlacementMode="Inline"
                                                      ToolTip="파형의 세로 크기. 클수록 Y축 범위가 넓어짐&#x0a;예: Amp=5 → Y값 범위 -5~+5"
                                                      Value="{Binding Amplitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <!--  Row 2  -->
                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,15,10,0">
                                        <TextBlock Margin="0,0,0,5" Text="Phase (radians)"
                                                   ToolTip="신호의 초기 위상 (시작 지점 이동)" />
                                        <ui:NumberBox Maximum="6.28" Minimum="0" SpinButtonPlacementMode="Inline"
                                                      ToolTip="파형을 좌우로 이동. 0~6.28 (0~2π)&#x0a;예: π(3.14) = 반주기 이동"
                                                      Value="{Binding Phase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,15,10,0">
                                        <TextBlock Margin="0,0,0,5" Text="Offset"
                                                   ToolTip="신호의 Y축 오프셋 (상하 이동)" />
                                        <ui:NumberBox Maximum="10" Minimum="-10" SpinButtonPlacementMode="Inline"
                                                      ToolTip="파형을 Y축 방향으로 이동&#x0a;예: Offset=2 → 전체 파형이 위로 2만큼 이동"
                                                      Value="{Binding Offset, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </ui:CardExpander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
