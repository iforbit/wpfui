<Page x:Class="Wpf.Ui.Demo.Mvvm.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:converters="clr-namespace:Wpf.Ui.Demo.Mvvm.Converter"
      xmlns:ctrlHelper="clr-namespace:Wpf.Ui.Demo.Mvvm.Helpers"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:Wpf.Ui.Demo.Mvvm.Views.Pages"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:Wpf.Ui.Demo.Mvvm.ViewModels"
      xmlns:wpf="http://schemas.vortice.windows.io"
      Title="DashboardPage"
      d:DataContext="{d:DesignInstance local:DashboardPage,
                                       IsDesignTimeCreatable=True}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Cursor=""
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToTextConverter x:Key="BooleanToTextConverter" />
        <ui:Ribbon x:Key="DashboardPageRibbon">
            <!--  페이지에 필요한 RibbonTabItem, RibbonGroupBox, Button 등을 정의  -->
            <ui:RibbonTabItem Header="Dashboard">
                <ui:RibbonGroupBox Header="Group 1" IsLauncherVisible="False" IsSeparatorVisible="False">
                    <ui:RibbonButton Header="Grey"
                                     Icon="{ui:SymbolIcon Mail28}"
                                     LargeIcon="{ui:SymbolIcon Mail28,
                                                               FontSize='32'}"
                                     SizeDefinition="Large" />

                    <ui:RibbonButton Header="Grey"
                                     Icon="{ui:SymbolIcon Mail28}"
                                     LargeIcon="{ui:SymbolIcon Mail28,
                                                               FontSize='32'}"
                                     SizeDefinition="Large" />

                </ui:RibbonGroupBox>
            </ui:RibbonTabItem>


        </ui:Ribbon>
    </Page.Resources>

    <Grid>
        <!--  실제 TabControl 적용  -->
        <ui:DockedTabControl>

            <ui:DockedTabItem Header="📄 상태" IsVisibleInStrip="True">

                <Grid Margin="32">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock VerticalAlignment="Center" FontSize="20" Text="Graph Viewer" />
                            <TextBlock VerticalAlignment="Center" Text="{Binding ViewModel.StatusMessage}" />


                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <!--  오버레이 FPS 텍스트  -->
                            <ui:TextBlock x:Name="FpsTextBlock"
                                          Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                                          FontTypography="BodyStrong" Foreground="Lime" Text="FPS: -" />

                            <ui:TextBlock x:Name="RenderTextBlock"
                                          Margin="10" HorizontalAlignment="Left" VerticalAlignment="Top"
                                          FontTypography="BodyStrong" Foreground="Cyan" Text="FPS: -" />

                            <!--  Signal 수신 속도 표시  -->
                            <ui:TextBlock Margin="16,0,0,0" VerticalAlignment="Center" FontTypography="BodyStrong"
                                          Foreground="Orange"
                                          Text="{Binding ViewModel.ReceiveRateText}" />

                        </StackPanel>
                    </StackPanel>

                    <ui:DXGraph x:Name="DxGraph"
                                Grid.Row="1" Margin="0,16,0,0" HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch" />
                </Grid>
            </ui:DockedTabItem>
        </ui:DockedTabControl>
    </Grid>
</Page>
