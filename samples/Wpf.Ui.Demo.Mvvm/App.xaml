<Application x:Class="Wpf.Ui.Demo.Mvvm.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Wpf.Ui.Demo.Mvvm.Converter"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             DispatcherUnhandledException="OnDispatcherUnhandledException"
             Exit="OnExit"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="TabViewSelectedItemBorderBrush" Color="#FF007ACC" />
            <converters:BoolToBrushConverter x:Key="BoolToBrushConverter"
                                             FalseBrush="Gray" TrueBrush="LimeGreen" />

            <converters:BoolToSymbolConverter x:Key="BoolToSymbolConverter"
                                              FalseSymbol="PlugConnected20" TrueSymbol="PlugConnectedCheckmark20" />
            <DataTemplate x:Key="IedItemTemplate">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="{Binding Name}" />

                    <!--  상태 기반 색상 변경 + 클릭 시 LoadedCommand 호출  -->
                    <Button Margin="6,0,0,0" Padding="0" VerticalAlignment="Center"
                            Command="{Binding LoadedCommand}">
                        <ui:SymbolIcon Foreground="{Binding IsConnected, Converter={StaticResource BoolToBrushConverter}}" Symbol="{Binding IsConnected, Converter={StaticResource BoolToSymbolConverter}}" />
                    </Button>
                </StackPanel>
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
