<Page x:Class="Wpf.Ui.Gallery.Views.Pages.Media.KeyframeTimelinePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Wpf.Ui.Gallery.Controls"
      xmlns:local="clr-namespace:Wpf.Ui.Gallery.Views.Pages.Media"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="KeyframeTimelinePage"
      controls:PageControlDocumentation.DocumentationType="{x:Type ui:KeyframeTimeline}"
      d:DataContext="{d:DesignInstance local:KeyframeTimelinePage,
                                       IsDesignTimeCreatable=False}"
      d:DesignHeight="600"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <StackPanel Margin="0,0,0,24">
        <!--  Basic KeyframeTimeline  -->
        <controls:ControlExample Margin="0" HeaderText="Basic Keyframe Timeline with scrubber and keyframe points." XamlCode="&lt;ui:KeyframeTimeline Duration=&quot;2.0&quot; CurrentTime=&quot;0.5&quot; /&gt;">
            <StackPanel>
                <ui:KeyframeTimeline x:Name="BasicTimeline"
                                     Height="80"
                                     CurrentTime="{Binding ViewModel.CurrentTime, Mode=TwoWay}"
                                     Duration="{Binding ViewModel.Duration}" />

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  Duration control  -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" Text="Duration: " />
                        <ui:NumberBox LargeChange="1" Maximum="10" Minimum="0.5"
                                      SmallChange="0.5"
                                      Value="{Binding ViewModel.Duration, Mode=TwoWay}" />
                        <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="s" />
                    </StackPanel>

                    <!--  Current time display  -->
                    <TextBlock Grid.Column="2" VerticalAlignment="Center"
                               Style="{DynamicResource CaptionTextBlockStyle}">
                        <Run Text="Current: " />
                        <Run FontWeight="SemiBold" Text="{Binding ViewModel.CurrentTime, StringFormat={}{0:F2}}" />
                        <Run Text="s" />
                    </TextBlock>
                </Grid>
            </StackPanel>
        </controls:ControlExample>

        <!--  Interactive KeyframeTimeline with Segments  -->
        <controls:ControlExample Margin="0,36,0,0" HeaderText="Interactive timeline with keyframe and segment management." XamlCode="&lt;ui:KeyframeTimeline KeyframePoints=&quot;{Binding Points}&quot; KeyframeSegments=&quot;{Binding Segments}&quot; /&gt;">
            <StackPanel>
                <ui:KeyframeTimeline x:Name="InteractiveTimeline"
                                     Height="80"
                                     CurrentTime="{Binding ViewModel.CurrentTime, Mode=TwoWay}"
                                     SelectedPoint="{Binding ViewModel.SelectedKeyframe, Mode=TwoWay}"
                                     SelectedSegment="{Binding ViewModel.SelectedSegment, Mode=TwoWay}"
                                     KeyframePoints="{Binding ViewModel.KeyframePoints}"
                                     KeyframeSegments="{Binding ViewModel.KeyframeSegments}"
                                     Duration="{Binding ViewModel.Duration}" />

                <!--  Control buttons  -->
                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <ui:Button Margin="0,0,8,0"
                               Command="{Binding ViewModel.PlayCommand}"
                               Content="Play"
                               Icon="{ui:SymbolIcon Play24}" />
                    <ui:Button Margin="0,0,8,0"
                               Command="{Binding ViewModel.StopCommand}"
                               Content="Stop"
                               Icon="{ui:SymbolIcon Stop24}" />
                    <ui:Button Margin="0,0,8,0"
                               Command="{Binding ViewModel.AddKeyframeCommand}"
                               Content="Add Keyframe"
                               Icon="{ui:SymbolIcon Add24}" />
                    <ui:Button Margin="0,0,8,0"
                               Command="{Binding ViewModel.RemoveKeyframeCommand}"
                               Content="Remove"
                               Icon="{ui:SymbolIcon Delete24}"
                               IsEnabled="{Binding ViewModel.SelectedKeyframe, Converter={StaticResource NullToBoolConverter}}" />
                    <ui:Button Command="{Binding ViewModel.ClearKeyframesCommand}"
                               Content="Clear All"
                               Icon="{ui:SymbolIcon DismissCircle24}" />
                </StackPanel>

                <!--  Status  -->
                <TextBlock Margin="0,8,0,0"
                           Style="{DynamicResource CaptionTextBlockStyle}"
                           Text="{Binding ViewModel.StatusText}" />
            </StackPanel>
        </controls:ControlExample>

        <!--  Compact Style  -->
        <controls:ControlExample Margin="0,36,0,0" HeaderText="Compact style timeline for property panels." XamlCode="&lt;ui:KeyframeTimeline Style=&quot;{StaticResource CompactKeyframeTimelineStyle}&quot; /&gt;">
            <StackPanel>
                <Border Padding="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Margin="0,0,0,8" FontWeight="SemiBold"
                                   Text="Animation Properties" />

                        <!--  Property name + Timeline  -->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Opacity" />
                            <ui:KeyframeTimeline Grid.Column="1" Height="30"
                                                 Style="{StaticResource CompactKeyframeTimelineStyle}"
                                                 Duration="1.0" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Rotation" />
                            <ui:KeyframeTimeline Grid.Column="1" Height="30"
                                                 Style="{StaticResource CompactKeyframeTimelineStyle}"
                                                 Duration="1.0" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Margin="0,8,0,0"
                           Style="{DynamicResource CaptionTextBlockStyle}"
                           Text="Compact style is ideal for property panels and inspector views." />
            </StackPanel>
        </controls:ControlExample>

        <!--  Animation Preview  -->
        <controls:ControlExample Margin="0,36,0,0" HeaderText="Timeline with animation preview." XamlCode="&lt;ui:KeyframeTimeline CurrentTimeChanged=&quot;OnTimeChanged&quot; /&gt;">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="150" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ui:KeyframeTimeline x:Name="PreviewTimeline"
                                         Height="80"
                                         CurrentTime="{Binding ViewModel.CurrentTime, Mode=TwoWay}"
                                         CurrentTimeChanged="OnPreviewTimelineCurrentTimeChanged" Duration="2.0" />

                    <TextBlock Margin="0,8,0,0"
                               Style="{DynamicResource CaptionTextBlockStyle}"
                               Text="Drag the scrubber to preview animation state" />
                </StackPanel>

                <!--  Preview area  -->
                <Border Grid.Column="1" Margin="16,0,0,0"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <Grid>
                        <Grid Width="60" Height="60" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="PreviewRotation" Angle="0" />
                            </Grid.RenderTransform>
                            <!-- 원 배경 -->
                            <Ellipse Fill="{DynamicResource AccentFillColorDefaultBrush}" />
                            <!-- 회전 표시용 선 -->
                            <Rectangle Width="4" Height="25"
                                       Fill="White"
                                       VerticalAlignment="Top"
                                       HorizontalAlignment="Center"
                                       Margin="0,5,0,0"
                                       RadiusX="2" RadiusY="2" />
                        </Grid>
                        <TextBlock Margin="0,0,0,8" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Text="Preview" />
                    </Grid>
                </Border>
            </Grid>
        </controls:ControlExample>
    </StackPanel>
</Page>
