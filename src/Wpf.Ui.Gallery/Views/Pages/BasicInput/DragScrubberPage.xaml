<Page x:Class="Wpf.Ui.Gallery.Views.Pages.BasicInput.DragScrubberPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Wpf.Ui.Gallery.Controls"
      xmlns:local="clr-namespace:Wpf.Ui.Gallery.Views.Pages.BasicInput"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="DragScrubberPage"
      controls:PageControlDocumentation.DocumentationType="{x:Type ui:DragScrubber}"
      d:DataContext="{d:DesignInstance local:DragScrubberPage,
                                       IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <StackPanel Margin="0,0,0,24">
        <controls:ControlExample Margin="0" HeaderText="Unity Inspector style drag scrubber control." XamlCode="&lt;ui:DragScrubber Value=&quot;50&quot; /&gt;">
            <StackPanel>
                <ui:DragScrubber x:Name="BasicDragScrubber"
                                 Label="Value" Maximum="100" Minimum="0"
                                 Precision="0" Step="1" Value="50" />
                <TextBlock Margin="0,8,0,0"
                           Style="{DynamicResource CaptionTextBlockStyle}"
                           Text="{Binding Value, ElementName=BasicDragScrubber, StringFormat={}Current Value: {0}}" />
            </StackPanel>
        </controls:ControlExample>

        <controls:ControlExample Margin="0,36,0,0" HeaderText="DragScrubber with label and decimal precision." XamlCode="&lt;ui:DragScrubber Label=&quot;Width&quot; Value=&quot;25.5&quot; Step=&quot;0.1&quot; Precision=&quot;1&quot; /&gt;">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center"
                               Text="Width:" />
                    <ui:DragScrubber x:Name="LabeledDragScrubber"
                                     Grid.Column="1" Label="Size" Maximum="100"
                                     Minimum="0" Precision="1" Step="0.1"
                                     Value="25.5" />
                </Grid>
                <TextBlock Margin="0,8,0,0"
                           Style="{DynamicResource CaptionTextBlockStyle}"
                           Text="{Binding Value, ElementName=LabeledDragScrubber, StringFormat={}Width: {0:F1} px}" />
            </StackPanel>
        </controls:ControlExample>

        <controls:ControlExample Margin="0,36,0,0" HeaderText="DragScrubber with keyboard modifiers (Ctrl for precision, Shift for fast)." XamlCode="&lt;ui:DragScrubber DragSensitivity=&quot;2.0&quot; /&gt;">
            <StackPanel>
                <ui:DragScrubber x:Name="ModifierDragScrubber"
                                 DragSensitivity="2.0" Label="Test" Maximum="50"
                                 Minimum="-50" Precision="2" Step="1"
                                 Value="10" />
                <TextBlock Margin="0,8,0,0" Style="{DynamicResource CaptionTextBlockStyle}">
                    <Run Text="Value: " />
                    <Run Text="{Binding Value, ElementName=ModifierDragScrubber, StringFormat={}{0:F2}}" />
                    <LineBreak />
                    <Run FontStyle="Italic" Text="Drag normally, hold Ctrl for precision (0.1x), Shift for fast (10x)" />
                </TextBlock>
            </StackPanel>
        </controls:ControlExample>

        <controls:ControlExample Margin="0,36,0,0" HeaderText="Compact DragScrubber with Unity-style labels for PropertyPane layout." XamlCode="&lt;ui:DragScrubber Style=&quot;{StaticResource CompactDragScrubberStyle}&quot; Label=&quot;X&quot; /&gt;">
            <StackPanel>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="4" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Unity Inspector 스타일 - 라벨 드래그 가능  -->
                    <ui:DragScrubber x:Name="CompactX"
                                     Grid.Row="0" Label="Xsdsd" Maximum="1000"
                                     Minimum="0" Precision="0" Step="1"
                                     Style="{StaticResource CompactDragScrubberStyle}"
                                     Value="100" />

                    <ui:DragScrubber x:Name="CompactY"
                                     Grid.Row="1" Label="Y" Maximum="1000"
                                     Minimum="0" Precision="0" Step="1"
                                     Style="{StaticResource CompactDragScrubberStyle}"
                                     Value="50" />

                    <ui:DragScrubber x:Name="CompactZ"
                                     Grid.Row="2" Label="Z" Maximum="100"
                                     Minimum="-100" Precision="0" Step="1"
                                     Style="{StaticResource CompactDragScrubberStyle}"
                                     Value="0" />
                </Grid>
                <TextBlock Margin="0,8,0,0" Style="{DynamicResource CaptionTextBlockStyle}">
                    <Run Text="Position: (" />
                    <Run Text="{Binding Value, ElementName=CompactX}" /><Run Text=", " />
                    <Run Text="{Binding Value, ElementName=CompactY}" /><Run Text=", " />
                    <Run Text="{Binding Value, ElementName=CompactZ}" /><Run Text=")" />
                </TextBlock>
            </StackPanel>
        </controls:ControlExample>
    </StackPanel>
</Page>