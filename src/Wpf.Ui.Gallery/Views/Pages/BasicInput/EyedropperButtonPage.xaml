<Page x:Class="Wpf.Ui.Gallery.Views.Pages.BasicInput.EyedropperButtonPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:controls="clr-namespace:Wpf.Ui.Gallery.Controls"
      xmlns:local="clr-namespace:Wpf.Ui.Gallery.Views.Pages.BasicInput"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="EyedropperButtonPage"
      d:DataContext="{d:DesignInstance local:EyedropperButtonPage,
                                       IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <StackPanel Margin="0,0,0,24">
        <controls:ControlExample Margin="0" HeaderText="Pick a color from anywhere on screen." XamlCode="&lt;ui:EyedropperButton Content=&quot;Pick Color&quot; ColorPicked=&quot;OnColorPicked&quot; /&gt;">
            <StackPanel HorizontalAlignment="Left" Orientation="Vertical">
                <!--  Color Board  -->
                <TextBlock Margin="0,0,0,8" Text="Click the button, then click anywhere on screen to pick a color:" />

                <Border x:Name="ColorBoard"
                        Width="200" Height="200" Background="LightGray"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1" CornerRadius="8" />

                <!--  Eyedropper Button  -->
                <ui:EyedropperButton x:Name="EyedropperBtn"
                                     Margin="0,16,0,0" HorizontalAlignment="Left" ColorPicked="OnColorPicked"
                                     Content="Pick Color"
                                     Icon="{ui:SymbolIcon Eyedropper24}"
                                     PickingCancelled="OnPickingCancelled" />

                <!--  Selected Color Display  -->
                <TextBlock x:Name="ColorText"
                           Margin="0,8,0,0" Text="Selected: None" />
            </StackPanel>
        </controls:ControlExample>

        <controls:ControlExample Margin="0,32,0,0" HeaderText="Eyedropper with custom content." XamlCode="&lt;ui:EyedropperButton&gt;&#10;    &lt;StackPanel Orientation=&quot;Horizontal&quot;&gt;&#10;        &lt;ui:SymbolIcon Symbol=&quot;Eyedropper24&quot; /&gt;&#10;        &lt;TextBlock Text=&quot;Sample Color&quot; Margin=&quot;8,0,0,0&quot; /&gt;&#10;    &lt;/StackPanel&gt;&#10;&lt;/ui:EyedropperButton&gt;">
            <StackPanel Orientation="Horizontal">
                <ui:EyedropperButton ColorPicked="OnColorPicked2">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Eyedropper24" />
                        <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="Sample Color" />
                    </StackPanel>
                </ui:EyedropperButton>

                <Border x:Name="ColorBoard2"
                        Width="32" Height="32" Margin="16,0,0,0"
                        VerticalAlignment="Center" Background="LightGray"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1" CornerRadius="4" />
            </StackPanel>
        </controls:ControlExample>
    </StackPanel>
</Page>
