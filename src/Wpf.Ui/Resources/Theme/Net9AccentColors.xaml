<!--
    .NET 9 WPF Fluent Theme Accent Color Integration
    
    This resource dictionary provides integration with .NET 9's new system accent color support.
    These resources automatically adapt to the user's Windows accent color selection.
    
    Usage:
    - Merge this dictionary in your Application.Resources
    - Use DynamicResource for automatic accent color updates
    
    Example:
    <Button Background="{DynamicResource SystemAccentColorBrush}"/>
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- .NET 9 System Accent Color Resources -->
    
    <!-- Primary System Accent Colors -->
    <!-- .NET 9 SystemColors.AccentColorBrush를 동적으로 참조 -->
    <SolidColorBrush x:Key="SystemAccentColorBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />
    
    <!-- Accent Color Light Variants for .NET 9 compatibility -->
    <SolidColorBrush x:Key="SystemAccentColorLight1Brush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.8" />
                     
    <SolidColorBrush x:Key="SystemAccentColorLight2Brush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.6" />
                     
    <SolidColorBrush x:Key="SystemAccentColorLight3Brush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.4" />

    <!-- Accent Color Dark Variants -->
    <SolidColorBrush x:Key="SystemAccentColorDark1Brush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.9" />
                     
    <SolidColorBrush x:Key="SystemAccentColorDark2Brush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.7" />
                     
    <SolidColorBrush x:Key="SystemAccentColorDark3Brush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.5" />

    <!-- Enhanced WPF UI Integration -->
    
    <!-- Replace static accent colors with dynamic system colors -->
    <SolidColorBrush x:Key="SystemFillColorAttentionBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />
                     
    <!-- Attention background with system accent -->
    <SolidColorBrush x:Key="SystemFillColorAttentionBackgroundBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.1" />

    <!-- Focus stroke with system accent -->
    <SolidColorBrush x:Key="FocusStrokeColorSystemBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />
                     
    <!-- Control accent stroke -->
    <SolidColorBrush x:Key="ControlStrokeColorOnSystemAccentBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.8" />

    <!-- Button and Control Integration -->
    
    <!-- Primary button with system accent -->
    <SolidColorBrush x:Key="ButtonBackgroundSystemAccentBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />
                     
    <!-- Hovered state -->
    <SolidColorBrush x:Key="ButtonBackgroundSystemAccentHoverBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.85" />
                     
    <!-- Pressed state -->
    <SolidColorBrush x:Key="ButtonBackgroundSystemAccentPressedBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.7" />

    <!-- Navigation and Selection -->
    
    <!-- Navigation view item selected -->
    <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.15" />
                     
    <!-- Tab item selected -->
    <SolidColorBrush x:Key="TabViewItemHeaderBackgroundSelectedBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.1" />

    <!-- Progress and Status -->
    
    <!-- Progress bar fill -->
    <SolidColorBrush x:Key="ProgressBarFillBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />
                     
    <!-- Slider thumb -->
    <SolidColorBrush x:Key="SliderThumbBackgroundBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />

    <!-- Hyperlink colors -->
    <SolidColorBrush x:Key="HyperlinkForegroundBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" />
                     
    <SolidColorBrush x:Key="HyperlinkForegroundHoverBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.8" />

    <!-- Text selection -->
    <SolidColorBrush x:Key="TextSelectionHighlightColorBrush" 
                     Color="{DynamicResource {x:Static SystemColors.AccentColorKey}}" 
                     Opacity="0.3" />

</ResourceDictionary>