<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="ContentControlThemeFontFamily">Segoe Ui</FontFamily>

    <!--<FontFamily x:Key="SegoeFluentIcons">Segoe Fluent Icons</FontFamily>-->

    <!--  https://github.com/microsoft/fluentui-system-icons  -->
    <FontFamily x:Key="FluentSystemIcons">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#FluentSystemIcons-Regular</FontFamily>

    <!--  https://github.com/microsoft/fluentui-system-icons  -->
    <FontFamily x:Key="FluentSystemIconsFilled">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#FluentSystemIcons-Filled</FontFamily>

    <!--  https://github.com/microsoft/fluentui-system-icons  -->
    <FontFamily x:Key="SegoeFluentIcons">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#Segoe Fluent Icons</FontFamily>

    <!--  https://github.com/google/material-design-icons  -->
    <FontFamily x:Key="MaterialIcons-Regular">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#Material Icons</FontFamily>

    <!--  https://github.com/twbs/icons  -->
    <FontFamily x:Key="BootstrapIcons">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#bootstrap-icons</FontFamily>

    <!--  Electrical symbols from diagrams.net converted via IcoMoon  -->
    <FontFamily x:Key="ElectricalIcons">pack://application:,,,/Wpf.Ui;component/Resources/Fonts/#electrical-icons</FontFamily>
</ResourceDictionary>
