      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="IsMouseOver" Value="True" />
          <Condition Property="IsPressed" Value="False" />
          <Condition Property="IsChecked" Value="True" />
        </MultiTrigger.Conditions>
        <Setter TargetName="border" Property="Background" Value="{DynamicResource ToggleButtonForegroundCheckedPointerOver}" />
      </MultiTrigger>
      <Trigger Property="IsPressed" Value="True">
        <Setter TargetName="border" Property="Background" Value="{DynamicResource ToggleButtonBackgroundPressed}" />
        <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ToggleButtonBorderBrushPressed}" />
