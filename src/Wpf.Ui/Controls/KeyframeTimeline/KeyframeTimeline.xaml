<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Wpf.Ui.Controls">

    <!--  Segment Resize Handle Thumb Style  -->
    <Style x:Key="SegmentResizeHandleStyle" TargetType="Thumb">
        <Setter Property="Width" Value="6" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="HandleBorder"
                            Background="Transparent"
                            BorderBrush="{DynamicResource AccentFillColorDefaultBrush}"
                            BorderThickness="0" CornerRadius="2" Opacity="0" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HandleBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="HandleBorder" Property="Opacity" Value="0.6" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="HandleBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="HandleBorder" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Keyframe Segment Style (Range Bar)  -->
    <Style x:Key="KeyframeSegmentStyle" TargetType="Border">
        <Setter Property="Height" Value="{Binding SegmentHeight, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}" />
        <Setter Property="CornerRadius" Value="2" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="ToolTip" Value="{Binding TooltipText}" />
        <Setter Property="Background">
            <Setter.Value>
                <MultiBinding Converter="{x:Static controls:KeyframeSegmentBrushConverter.Instance}">
                    <Binding Path="SegmentBrush" />
                    <Binding Path="SegmentBrush" RelativeSource="{RelativeSource AncestorType=controls:KeyframeTimeline}" />
                </MultiBinding>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Opacity" Value="0.8" />
            </Trigger>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                <Setter Property="BorderThickness" Value="2" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!--  Keyframe Point Thumb Style (드래그 가능)  -->
    <Style x:Key="KeyframePointThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!--  외부 원 (선택 시 강조)  -->
                        <Ellipse x:Name="OuterRing"
                                 Width="14" Height="14" Fill="Transparent"
                                 Opacity="0"
                                 Stroke="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                 StrokeThickness="2" />
                        <!--  내부 원  -->
                        <Ellipse x:Name="InnerDot"
                                 Width="10" Height="10"
                                 Fill="{DynamicResource AccentFillColorDefaultBrush}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="OuterRing" Property="Opacity" Value="0.5" />
                            <Setter TargetName="InnerDot" Property="Width" Value="12" />
                            <Setter TargetName="InnerDot" Property="Height" Value="12" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="OuterRing" Property="Opacity" Value="0.8" />
                            <Setter TargetName="InnerDot" Property="Width" Value="12" />
                            <Setter TargetName="InnerDot" Property="Height" Value="12" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="OuterRing" Property="Opacity" Value="1" />
                            <Setter TargetName="InnerDot" Property="Fill" Value="{DynamicResource SystemFillColorAttentionBrush}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Scrubber Thumb Style  -->
    <Style x:Key="ScrubberThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="18" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!--  삼각형 헤드  -->
                        <controls:SymbolIcon HorizontalAlignment="Center" VerticalAlignment="Top" Filled="True"
                                             Foreground="{Binding ScrubberBrush, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}"
                                             Symbol="TriangleDown20" />
                        <!--  세로선  -->
                        <Rectangle Width="2" Margin="5,5,5,0"
                                   Fill="{Binding ScrubberBrush, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  KeyframeTimeline 기본 스타일  -->
    <Style TargetType="{x:Type controls:KeyframeTimeline}">
        <Setter Property="MinHeight" Value="60" />
        <Setter Property="MaxHeight" Value="100" />
        <Setter Property="ScrubberBrush" Value="#FFFF4444" />
        <Setter Property="TrackBackground" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KeyframeTimeline}">
                    <Border Padding="8,4"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="0,1,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!--  시간 눈금자  -->
                            <Canvas x:Name="PART_TimeRuler"
                                    Grid.Row="0" Background="Transparent" ClipToBounds="True" />

                            <!--  Keyframe 트랙 + Scrubber  -->
                            <Grid Grid.Row="1">
                                <!--  Keyframe 트랙 배경  -->
                                <Canvas x:Name="PART_KeyframeTrack"
                                        Background="{TemplateBinding TrackBackground}"
                                        ClipToBounds="True">
                                    <!--  Segment (Range Bar) 레이어 - 포인트 뒤에 배치  -->
                                    <ItemsControl x:Name="PART_SegmentItemsControl" Canvas.Top="11">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="{Binding CanvasWidth}" Tag="{Binding}">
                                                    <!--  세그먼트 바디  -->
                                                    <Border Style="{StaticResource KeyframeSegmentStyle}" />
                                                    <!--  왼쪽 리사이즈 핸들  -->
                                                    <Thumb x:Name="LeftHandle"
                                                           Height="{Binding SegmentHeight, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}"
                                                           HorizontalAlignment="Left"
                                                           Style="{StaticResource SegmentResizeHandleStyle}"
                                                           Tag="Left" />
                                                    <!--  오른쪽 리사이즈 핸들  -->
                                                    <Thumb x:Name="RightHandle"
                                                           Height="{Binding SegmentHeight, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}"
                                                           HorizontalAlignment="Right"
                                                           Style="{StaticResource SegmentResizeHandleStyle}"
                                                           Tag="Right" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!--  Keyframe 포인트들  -->
                                    <ItemsControl x:Name="PART_KeyframeItemsControl" Canvas.Top="8">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <Canvas />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Thumb Style="{StaticResource KeyframePointThumbStyle}"
                                                       Tag="{Binding}"
                                                       ToolTip="{Binding TooltipText}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Canvas>

                                <!--  Scrubber (현재 시간 표시)  -->
                                <Canvas ClipToBounds="False">
                                    <Thumb x:Name="PART_Scrubber"
                                           Canvas.Top="0"
                                           Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                           Style="{StaticResource ScrubberThumbStyle}" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  컴팩트 스타일 (높이 최소화)  -->
    <Style x:Key="CompactKeyframeTimelineStyle" TargetType="{x:Type controls:KeyframeTimeline}">
        <Setter Property="MinHeight" Value="40" />
        <Setter Property="MaxHeight" Value="50" />
        <Setter Property="ScrubberBrush" Value="#FFFF4444" />
        <Setter Property="TrackBackground" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:KeyframeTimeline}">
                    <Border Padding="4,2"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="4">
                        <Grid>
                            <!--  Keyframe 트랙 + Scrubber (눈금자 없음)  -->
                            <Canvas x:Name="PART_KeyframeTrack"
                                    Background="{TemplateBinding TrackBackground}"
                                    ClipToBounds="True">
                                <!--  Segment (Range Bar) 레이어  -->
                                <ItemsControl x:Name="PART_SegmentItemsControl" Canvas.Top="7">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Width="{Binding CanvasWidth}" Tag="{Binding}">
                                                <!--  세그먼트 바디  -->
                                                <Border Style="{StaticResource KeyframeSegmentStyle}" />
                                                <!--  왼쪽 리사이즈 핸들  -->
                                                <Thumb x:Name="LeftHandle"
                                                       Height="{Binding SegmentHeight, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}"
                                                       HorizontalAlignment="Left"
                                                       Style="{StaticResource SegmentResizeHandleStyle}"
                                                       Tag="Left" />
                                                <!--  오른쪽 리사이즈 핸들  -->
                                                <Thumb x:Name="RightHandle"
                                                       Height="{Binding SegmentHeight, RelativeSource={RelativeSource AncestorType=controls:KeyframeTimeline}}"
                                                       HorizontalAlignment="Right"
                                                       Style="{StaticResource SegmentResizeHandleStyle}"
                                                       Tag="Right" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!--  Keyframe 포인트들  -->
                                <ItemsControl x:Name="PART_KeyframeItemsControl" Canvas.Top="4">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Thumb Style="{StaticResource KeyframePointThumbStyle}"
                                                   Tag="{Binding}"
                                                   ToolTip="{Binding TooltipText}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Canvas>

                            <!--  Scrubber  -->
                            <Canvas ClipToBounds="False">
                                <Thumb x:Name="PART_Scrubber"
                                       Canvas.Top="0"
                                       Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                       Style="{StaticResource ScrubberThumbStyle}" />
                            </Canvas>

                            <!--  빈 PART_TimeRuler (컴팩트 모드에서는 숨김)  -->
                            <Canvas x:Name="PART_TimeRuler" Visibility="Collapsed" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
