<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:System="clr-namespace:System;assembly=mscorlib">


    <Style x:Key="controls.Ribbon.Styles.ScrollBarLineButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Name="Border" Margin="0"
                            Background="{DynamicResource controls.Ribbon.Brushes.ScrollButton.Default.Background}"
                            BorderBrush="{DynamicResource controls.Ribbon.Brushes.ScrollButton.Default.Border}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Path x:Name="path"
                              Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{TemplateBinding Foreground}"
                              Style="{DynamicResource controls.Ribbon.Styles.Path.Arrow.LeftRight}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Background}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Border}" />
                        </MultiTrigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Background}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Border}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Border" Property="Background" Value="Transparent" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="Transparent" />
                            <Setter TargetName="path" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="controls.Ribbon.Styles.ScrollBarPageButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="Focusable" Value="false" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="controls.Ribbon.Styles.ScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="border"
                            Background="{DynamicResource controls.Ribbon.Brushes.ScrollThumb.Default.Background}"
                            BorderBrush="{DynamicResource controls.Ribbon.Brushes.ScrollThumb.Default.Border}"
                            BorderThickness="{TemplateBinding BorderThickness}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Background}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Border}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Background}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Border}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="controls.Ribbon.Styles.VerticalScrollBarLineButton" TargetType="{x:Type RepeatButton}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Border Name="Border" Margin="0"
                            Background="{DynamicResource controls.Ribbon.Brushes.ScrollButton.Default.Background}"
                            BorderBrush="{DynamicResource controls.Ribbon.Brushes.ScrollButton.Default.Border}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Path x:Name="path"
                              Data="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                              Stroke="{TemplateBinding Foreground}"
                              Style="{DynamicResource controls.Ribbon.Styles.Path.Arrow.UpDown}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsPressed" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Background}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Border}" />
                        </MultiTrigger>
                        <Trigger Property="IsPressed" Value="true">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Background}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Border}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter TargetName="Border" Property="Background" Value="Transparent" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="Transparent" />
                            <Setter TargetName="path" Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="controls.Ribbon.Styles.VerticalScrollBarThumb" TargetType="{x:Type Thumb}">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border x:Name="border"
                            Background="{DynamicResource controls.Ribbon.Brushes.ScrollThumb.Default.Background}"
                            BorderBrush="{DynamicResource controls.Ribbon.Brushes.ScrollThumb.Default.Border}"
                            BorderThickness="{TemplateBinding BorderThickness}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Background}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.Pressed.Border}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Background}" />
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource controls.Ribbon.Brushes.Button.MouseOver.Border}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="controls.Ribbon.Templates.VerticalScrollBar" TargetType="{x:Type ScrollBar}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="0.00001*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.RowSpan="3" Background="{DynamicResource controls.Ribbon.Brushes.ScrollBar.Background}" />
            <RepeatButton x:Name="repeatButton"
                          Grid.Row="0" Height="17" VerticalAlignment="Top"
                          Background="{DynamicResource controls.Ribbon.Brushes.White}"
                          Command="ScrollBar.LineUpCommand"
                          Content="{DynamicResource controls.Ribbon.Values.Arrow.Up}"
                          Style="{DynamicResource controls.Ribbon.Styles.VerticalScrollBarLineButton}" />
            <Track Name="PART_Track" Grid.Row="1" IsDirectionReversed="true"
                   ViewportSize="{TemplateBinding ViewportSize}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand" Style="{DynamicResource controls.Ribbon.Styles.ScrollBarPageButton}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb RenderTransformOrigin="0.5,0.5" Style="{DynamicResource controls.Ribbon.Styles.VerticalScrollBarThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand" Style="{DynamicResource controls.Ribbon.Styles.ScrollBarPageButton}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton x:Name="repeatButton1"
                          Grid.Row="2" Height="17"
                          Background="{DynamicResource controls.Ribbon.Brushes.White}"
                          Command="ScrollBar.LineDownCommand"
                          Content="{DynamicResource controls.Ribbon.Values.Arrow.Down}"
                          Style="{DynamicResource controls.Ribbon.Styles.VerticalScrollBarLineButton}" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="repeatButton" Property="Background" Value="{x:Null}" />
                <Setter TargetName="repeatButton1" Property="Background" Value="{x:Null}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="controls.Ribbon.Templates.HorizontalScrollBar" TargetType="{x:Type ScrollBar}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="0.00001*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border Grid.ColumnSpan="3" Margin="0"
                    Background="{DynamicResource controls.Ribbon.Brushes.ScrollBar.Background}" />
            <RepeatButton x:Name="repeatButton"
                          Grid.Column="0" Width="17"
                          Background="{DynamicResource controls.Ribbon.Brushes.White}"
                          Command="ScrollBar.LineLeftCommand"
                          Content="{DynamicResource controls.Ribbon.Values.Arrow.Left}"
                          Style="{DynamicResource controls.Ribbon.Styles.ScrollBarLineButton}" />
            <Track Name="PART_Track" Grid.Column="1" IsDirectionReversed="False"
                   ViewportSize="{TemplateBinding ViewportSize}">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand" Style="{DynamicResource controls.Ribbon.Styles.ScrollBarPageButton}" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Margin="0,0,0,0" Style="{DynamicResource controls.Ribbon.Styles.ScrollBarThumb}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand" Style="{DynamicResource controls.Ribbon.Styles.ScrollBarPageButton}" />
                </Track.IncreaseRepeatButton>
            </Track>
            <RepeatButton x:Name="repeatButton1"
                          Grid.Column="2" Width="17"
                          Background="{DynamicResource controls.Ribbon.Brushes.White}"
                          Command="ScrollBar.LineRightCommand"
                          Content="{DynamicResource controls.Ribbon.Values.Arrow.Right}"
                          Style="{DynamicResource controls.Ribbon.Styles.ScrollBarLineButton}" />
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="repeatButton" Property="Background" Value="{x:Null}" />
                <Setter TargetName="repeatButton1" Property="Background" Value="{x:Null}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <Style x:Key="controls.Ribbon.Styles.ScrollBar" TargetType="ScrollBar">
        <Setter Property="Foreground" Value="{DynamicResource controls.Ribbon.Brushes.Black}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="17" />
                <Setter Property="Template" Value="{DynamicResource controls.Ribbon.Templates.HorizontalScrollBar}" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Height" Value="Auto" />
                <Setter Property="Template" Value="{DynamicResource controls.Ribbon.Templates.VerticalScrollBar}" />
                <Setter Property="Width" Value="17" />
            </Trigger>
        </Style.Triggers>
        <Style.Resources>
            <!--
                Set the Thumb's minimum height to 36.
                The Thumb's minimum height is half the
                value of VerticalScrollBarButtonHeightKey.
            -->
            <System:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}">
                36
            </System:Double>
            <!--
                Set the Thumb's minimum height to 36.
                The Thumb's minimum height is half the
                value of VerticalScrollBarButtonHeightKey.
            -->
            <System:Double x:Key="{x:Static SystemParameters.VerticalScrollBarButtonHeightKey}">
                36
            </System:Double>
        </Style.Resources>
    </Style>

    <Style x:Key="controls.Ribbon.Styles.ScrollBarWhite" TargetType="ScrollBar">
        <Setter Property="Foreground" Value="{DynamicResource controls.Ribbon.Brushes.Black}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="17" />
                <Setter Property="Template" Value="{DynamicResource controls.Ribbon.Templates.HorizontalScrollBar}" />
                <Setter Property="Width" Value="Auto" />
            </Trigger>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Height" Value="Auto" />
                <Setter Property="Template" Value="{DynamicResource controls.Ribbon.Templates.VerticalScrollBar}" />
                <Setter Property="Width" Value="17" />
            </Trigger>
        </Style.Triggers>
        <Style.Resources>
            <!--
                Set the Thumb's minimum height to 36.
                The Thumb's minimum height is half the
                value of VerticalScrollBarButtonHeightKey.
            -->
            <System:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}">
                36
            </System:Double>
            <!--
                Set the Thumb's minimum height to 36.
                The Thumb's minimum height is half the
                value of VerticalScrollBarButtonHeightKey.
            -->
            <System:Double x:Key="{x:Static SystemParameters.VerticalScrollBarButtonHeightKey}">
                36
            </System:Double>
        </Style.Resources>
    </Style>
</ResourceDictionary>