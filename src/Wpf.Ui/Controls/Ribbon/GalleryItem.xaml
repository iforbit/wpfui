<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Wpf.Ui.Controls">

    <ControlTemplate x:Key="controls.Ribbon.Templates.GalleryItem" TargetType="{x:Type controls:GalleryItem}">
        <Border Background="{TemplateBinding Background}">
            <ContentPresenter Margin="{TemplateBinding Padding}" />
        </Border>
    </ControlTemplate>

    <Style x:Key="DefaultGalleryItemStyles" TargetType="{x:Type controls:GalleryItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="Padding" Value="1" />
        <Setter Property="Template" Value="{DynamicResource controls.Ribbon.Templates.GalleryItem}" />
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.5" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource NavigationViewItemBackgroundSelected}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource NavigationViewItemBackgroundPointerOver}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource NavigationViewItemBackgroundPressed}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>