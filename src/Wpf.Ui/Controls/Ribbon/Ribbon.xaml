<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Wpf.Ui.Controls"
    xmlns:internal="clr-namespace:Wpf.Ui.Internal"
    xmlns:rib="clr-namespace:Wpf.Ui.Controls.Ribbon"
    >

    <ControlTemplate x:Key="rib.Templates.Ribbon" TargetType="{x:Type rib:Ribbon}">
        <ControlTemplate.Resources>
        </ControlTemplate.Resources>
        <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1,1,1,0">
            <Grid x:Name="PART_LayoutRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <rib:RibbonTabControl x:Name="PART_RibbonTabControl" Grid.Row="1" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsCollapsed" Value="True">
                <Setter TargetName="PART_RibbonTabControl" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <Trigger Property="IsSimplified" Value="True">
                <Setter TargetName="PART_RibbonTabControl" Property="ContentHeight" Value="42" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <ControlTemplate x:Key="rib.Templates.RibbonTabControl"
                   TargetType="{x:Type rib:RibbonTabControl}">
        <Grid x:Name="ContentGrid"
            VerticalAlignment="Top"
              Background="{TemplateBinding Background}"
              KeyboardNavigation.TabNavigation="Local">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition x:Name="contentRow"
                       MinHeight="{TemplateBinding ContentHeight}"
                       MaxHeight="{TemplateBinding ContentHeight}" />
                <RowDefinition x:Name="contentGapRow"
                       MinHeight="{TemplateBinding ContentGapHeight}"
                       MaxHeight="{TemplateBinding ContentGapHeight}" />
            </Grid.RowDefinitions>
            <Grid x:Name="TabsGrid"
          Grid.Row="0"
          Margin="0"
          HorizontalAlignment="Stretch"
          Background="{DynamicResource rib.Brushes.RibbonTabControl.TabsGrid.Background}"
          KeyboardNavigation.TabIndex="1"
          TextElement.Foreground="{DynamicResource rib.Brushes.RibbonTabControl.TabsGrid.Foreground}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ContentPresenter Grid.Column="0"
                          VerticalAlignment="Stretch"
                          ContentSource="Menu" />
                <StackPanel Grid.Column="3"
                    Margin="0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
                    <StackPanel x:Name="PART_ToolbarPanel"
                        Orientation="Horizontal"
                        Visibility="{Binding IsToolBarVisible, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource Converters.BoolToVisibilityConverter}}" />

                </StackPanel>
            </Grid>

            <Border Grid.Row="1"
            Margin="{DynamicResource Fluent.Ribbon.Values.RibbonTabControl.Content.Margin}"
            HorizontalAlignment="Stretch"
            Background="{DynamicResource Fluent.Ribbon.Brushes.RibbonTabControl.Content.Background}"
            BorderBrush="{DynamicResource Fluent.Ribbon.Brushes.RibbonTabControl.Content.Border}"
            BorderThickness="{DynamicResource Fluent.Ribbon.Values.RibbonTabControl.Content.BorderThickness}"
            CornerRadius="{DynamicResource Fluent.Ribbon.Values.RibbonTabControl.Content.CornerRadius}"
            KeyboardNavigation.DirectionalNavigation="Contained"
            KeyboardNavigation.TabIndex="2"
            KeyboardNavigation.TabNavigation="Local"
            TextElement.Foreground="{DynamicResource Fluent.Ribbon.Brushes.RibbonTabControl.Content.Foreground}">
                <Grid>
                    <!-- We must use a dedicated border to prevent the effect from affecting font rendering... -->
                    <Border Background="{DynamicResource Fluent.Ribbon.Brushes.RibbonTabControl.Content.Background}"
                    BorderBrush="{DynamicResource Fluent.Ribbon.Brushes.RibbonTabControl.Content.Border}"
                    BorderThickness="0"
                    CornerRadius="{DynamicResource Fluent.Ribbon.Values.RibbonTabControl.Content.CornerRadius}"
                    Effect="{DynamicResource Fluent.Ribbon.Values.RibbonTabControl.Content.DropShadowEffect}" />

                    <ContentControl x:Name="mainContentControl"
                            Margin="0"
                            Focusable="False">
                               </ContentControl>
                </Grid>
            </Border>

        </Grid>
        <ControlTemplate.Triggers>
        </ControlTemplate.Triggers>
    </ControlTemplate>


    <Style x:Key="DefaultRibbonStyle" TargetType="{x:Type rib:Ribbon}">
        <Setter Property="internal:FrameworkHelper.UseLayoutRounding" Value="True" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="VerticalAlignment" Value="Top" />
        <Setter Property="Template" Value="{DynamicResource rib.Templates.Ribbon}"/>
    </Style>

    <Style BasedOn="{StaticResource DefaultRibbonStyle}" TargetType="{x:Type rib:Ribbon}" />
    
    <Style x:Key="DefaultRibbonTabControlStyle" TargetType="{x:Type rib:RibbonTabControl}">
        <Setter Property="Background" Value="{DynamicResource Background}" />
        <Setter Property="CanMinimize" Value="{Binding CanMinimize, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type rib:Ribbon}}, Mode=TwoWay}" />
        <Setter Property="CanUseSimplified" Value="{Binding CanUseSimplified, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type rib:Ribbon}}, Mode=TwoWay}" />
        <Setter Property="ContentGapHeight" Value="{Binding ContentGapHeight, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type rib:Ribbon}}}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource CardForeground}" />
        <Setter Property="IsMinimized" Value="{Binding IsMinimized, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type rib:Ribbon}}, Mode=TwoWay}" />
        <Setter Property="IsSimplified" Value="{Binding IsSimplified, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type rib:Ribbon}}, Mode=TwoWay}" />
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Template" Value="{DynamicResource rib.Templates.RibbonTabControl}" />
    </Style>
    
    

    <Style x:Key="DefaultRibbonTabStyle" TargetType="{x:Type rib:RibbonTabItem}">
        <Setter Property="Template" Value="{DynamicResource rib.Templates.RibbonTabItem}" />
    </Style>

    <Style x:Key="DefaultRibbonGroupBoxStyle" TargetType="{x:Type rib:RibbonGroupBox}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type rib:RibbonGroupBox}">
                    <GroupBox Header="{TemplateBinding Header}">
                    </GroupBox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DefaultRibbonButtonStyle" TargetType="{x:Type rib:RibbonButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type rib:RibbonButton}">
                    <StackPanel Orientation="Horizontal">
                        <ContentPresenter Content="{TemplateBinding Icon}" />
                        <TextBlock Text="{TemplateBinding Content}" Margin="5,0,0,0" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="Ribbon.Styles.MenuSeparator" TargetType="{x:Type Separator}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Grid Height="Auto">
                        <Path Height="1" Margin="32 1 3 2" VerticalAlignment="Center" Data="M0,0L1,0" Fill="{x:Null}" Stretch="Fill" Stroke="{StaticResource CardStrokeColorDefaultBrush}" StrokeDashArray="2 2" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>