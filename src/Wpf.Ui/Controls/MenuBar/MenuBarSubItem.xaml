<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Wpf.Ui.Controls">

    <!-- MenuBarSubItem SubmenuItem Template (leaf item) -->
    <ControlTemplate x:Key="MenuBarSubItemSubmenuItemTemplate" TargetType="{x:Type controls:MenuBarSubItem}">
        <Border
            x:Name="Border"
            Margin="2,1"
            Padding="6,4"
            Background="Transparent"
            CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Icon/Checkmark -->
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon" />
                    <!-- Header -->
                    <ColumnDefinition Width="*" />
                    <!-- Shortcut -->
                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut" />
                </Grid.ColumnDefinitions>

                <!-- Icon/Checkmark Container -->
                <Grid
                    Grid.Column="0"
                    Width="16"
                    Height="16"
                    Margin="0,0,6,0"
                    VerticalAlignment="Center">
                    <!-- Checkmark (shown when checked) -->
                    <controls:SymbolIcon
                        x:Name="CheckMark"
                        FontSize="12"
                        Symbol="Checkmark16"
                        Visibility="Collapsed" />
                    <!-- Icon -->
                    <ContentPresenter
                        x:Name="IconPresenter"
                        Width="{TemplateBinding IconSize}"
                        Height="{TemplateBinding IconSize}"
                        Content="{TemplateBinding Icon}" />
                </Grid>

                <!-- Header -->
                <ContentPresenter
                    x:Name="HeaderPresenter"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    ContentSource="Header"
                    RecognizesAccessKey="True" />

                <!-- Keyboard Shortcut -->
                <TextBlock
                    x:Name="InputGestureText"
                    Grid.Column="2"
                    Margin="16,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="{TemplateBinding InputGestureText}" />
            </Grid>
        </Border>
        <ControlTemplate.Triggers>
            <!-- Hide icon when checkable (checkmark takes its place) -->
            <Trigger Property="IsCheckable" Value="True">
                <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <!-- Show checkmark when checked -->
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
            </Trigger>
            <!-- Hide empty shortcut text -->
            <Trigger Property="InputGestureText" Value="">
                <Setter TargetName="InputGestureText" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <!-- Highlight on hover -->
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuBarItemBackgroundSelected}" />
            </Trigger>
            <!-- Disabled state -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                <Setter TargetName="InputGestureText" Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- MenuBarSubItem SubmenuHeader Template (has submenu) -->
    <ControlTemplate x:Key="MenuBarSubItemSubmenuHeaderTemplate" TargetType="{x:Type controls:MenuBarSubItem}">
        <Grid>
            <Border
                x:Name="Border"
                Margin="2,1"
                Padding="6,4"
                Background="Transparent"
                CornerRadius="3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Icon/Checkmark -->
                        <ColumnDefinition Width="Auto" SharedSizeGroup="Icon" />
                        <!-- Header -->
                        <ColumnDefinition Width="*" />
                        <!-- Arrow -->
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Icon/Checkmark Container -->
                    <Grid
                        Grid.Column="0"
                        Width="16"
                        Height="16"
                        Margin="0,0,6,0"
                        VerticalAlignment="Center">
                        <!-- Checkmark (shown when checked) -->
                        <controls:SymbolIcon
                            x:Name="CheckMark"
                            FontSize="12"
                            Symbol="Checkmark16"
                            Visibility="Collapsed" />
                        <!-- Icon -->
                        <ContentPresenter
                            x:Name="IconPresenter"
                            Width="{TemplateBinding IconSize}"
                            Height="{TemplateBinding IconSize}"
                            Content="{TemplateBinding Icon}" />
                    </Grid>

                    <!-- Header -->
                    <ContentPresenter
                        x:Name="HeaderPresenter"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        ContentSource="Header"
                        RecognizesAccessKey="True" />

                    <!-- Submenu Arrow -->
                    <controls:SymbolIcon
                        x:Name="Arrow"
                        Grid.Column="2"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="10"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Symbol="ChevronRight16" />
                </Grid>
            </Border>

            <!-- Submenu Popup -->
            <Popup
                x:Name="PART_Popup"
                AllowsTransparency="True"
                Focusable="False"
                HorizontalOffset="0"
                IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                Placement="Right"
                PlacementTarget="{Binding ElementName=Border}"
                PopupAnimation="Fade"
                VerticalOffset="-8">
                <Border
                    Margin="12"
                    Background="{DynamicResource FlyoutBackground}"
                    BorderBrush="{DynamicResource FlyoutBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="20"
                            Direction="270"
                            Opacity="0.25"
                            ShadowDepth="6"
                            Color="#000000" />
                    </Border.Effect>
                    <controls:PassiveScrollViewer
                        MaxHeight="400"
                        CanContentScroll="True"
                        HorizontalScrollBarVisibility="Disabled"
                        Style="{DynamicResource UiScrollViewer}"
                        VerticalScrollBarVisibility="Auto">
                        <Grid Grid.IsSharedSizeScope="True">
                            <StackPanel
                                Margin="4"
                                IsItemsHost="True"
                                KeyboardNavigation.DirectionalNavigation="Cycle" />
                        </Grid>
                    </controls:PassiveScrollViewer>
                </Border>
            </Popup>
        </Grid>
        <ControlTemplate.Triggers>
            <!-- Hide icon when checkable (checkmark takes its place) -->
            <Trigger Property="IsCheckable" Value="True">
                <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
            </Trigger>
            <!-- Show checkmark when checked -->
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
            </Trigger>
            <!-- Highlight on hover -->
            <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuBarItemBackgroundSelected}" />
            </Trigger>
            <!-- Highlight arrow when submenu open -->
            <Trigger Property="IsSubmenuOpen" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource MenuBarItemBackgroundSelected}" />
            </Trigger>
            <!-- Disabled state -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
                <Setter TargetName="Arrow" Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- MenuBarSubItem Style -->
    <Style TargetType="{x:Type controls:MenuBarSubItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="IconSize" Value="16" />
        <Setter Property="MinWidth" Value="140" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template" Value="{StaticResource MenuBarSubItemSubmenuItemTemplate}" />
        <Style.Triggers>
            <Trigger Property="Role" Value="SubmenuItem">
                <Setter Property="Template" Value="{StaticResource MenuBarSubItemSubmenuItemTemplate}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
                <Setter Property="Template" Value="{StaticResource MenuBarSubItemSubmenuHeaderTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
