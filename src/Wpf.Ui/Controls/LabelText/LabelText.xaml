<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Wpf.Ui.Controls"
                    xmlns:system="clr-namespace:System;assembly=System.Runtime">

    <!--  LabelText specific resources  -->
    <Thickness x:Key="LabelTextBorderThemeThickness">1,1,1,1</Thickness>
    <Thickness x:Key="LabelTextAccentBorderThemeThickness">0,0,0,1</Thickness>
    <Thickness x:Key="LabelTextLabelMargin">0,0,0,0</Thickness>
    <Thickness x:Key="LabelTextAdditionalContentMargin">8,0,0,0</Thickness>
    <system:Double x:Key="LabelTextLabelFloatedScale">0.75</system:Double>


    <!--  Default Label style for LabelText  -->
    <Style x:Key="DefaultLabelTextLabelStyle" TargetType="{x:Type Label}">
        <Setter Property="Foreground" Value="{DynamicResource TextControlPlaceholderForeground}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="Padding" Value="1,0" />
        <Setter Property="Margin" Value="{StaticResource LabelTextLabelMargin}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <!--  Telerik: Stretch로 변경  -->
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="IsHitTestVisible" Value="False" />
        <Setter Property="RenderTransformOrigin" Value="0,0.5" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <!--  Telerik: 선명한 렌더링  -->
        <Style.Triggers>
            <!--  Floated state styling (Telerik 방식)  -->
            <DataTrigger Binding="{Binding IsLabelFloated, RelativeSource={RelativeSource AncestorType=controls:LabelText}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource TextControlFocusedBorderBrush}" />
                <Setter Property="FontWeight" Value="Medium" />
                <Setter Property="Opacity" Value="1" />
                <!--  Telerik: 명시적 불투명도  -->
            </DataTrigger>
            <!--  Focused state styling  -->
            <DataTrigger Binding="{Binding IsFocused, RelativeSource={RelativeSource AncestorType=controls:LabelText}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource TextControlFocusedBorderBrush}" />
            </DataTrigger>
            <!--  HasLabel false state (Telerik 방식)  -->
            <DataTrigger Binding="{Binding HasLabel, RelativeSource={RelativeSource AncestorType=controls:LabelText}}" Value="False">
                <Setter Property="Margin" Value="0" />
            </DataTrigger>
            <!--  Disabled state (Telerik 방식)  -->
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="1" />
                <!--  Disabled 시에도 완전 불투명  -->
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  LabelText Control Template  -->
    <ControlTemplate x:Key="DefaultLabelTextControlTemplate" TargetType="{x:Type controls:LabelText}">
        <Grid x:Name="PART_RootElement"
              HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
              VerticalAlignment="{TemplateBinding VerticalAlignment}">

            <!--  Main content border  -->
            <Border x:Name="ContentBorder"
                    MinWidth="{TemplateBinding MinWidth}"
                    MinHeight="{TemplateBinding MinHeight}"
                    Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{TemplateBinding Border.CornerRadius}">

                <Grid HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="PART_LabelRowDefinition" Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--  Content area with TextBox and Label  -->
                    <!--  TextBox Content Host  -->
                    <controls:PassiveScrollViewer x:Name="PART_ContentHost"
                                                  Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                                                  Margin="0,15,0,0"
                                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                                  IsDeferredScrollingEnabled="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                                  IsTabStop="{TemplateBinding ScrollViewer.IsTabStop}"
                                                  Style="{DynamicResource DefaultTextBoxScrollViewerStyle}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"
                                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}" />

                    <!--  Floating Label  -->
                    <Label x:Name="PART_LabelElement"
                           Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                           VerticalAlignment="Center"
                           Content="{TemplateBinding Label}"
                           Style="{TemplateBinding LabelStyle}" />

                    <!--  Placeholder (fallback when no label)  -->
                    <TextBlock x:Name="PlaceholderTextBox"
                               Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                               Margin="1,0" Padding="1,0" VerticalAlignment="Center"
                               FontSize="{TemplateBinding FontSize}"
                               Foreground="{DynamicResource TextControlPlaceholderForeground}"
                               Text="{TemplateBinding PlaceholderText}"
                               Visibility="Collapsed" />

                    <!--  Clear Button  -->
                    <controls:Button x:Name="ClearButton"
                                     Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                                     MinWidth="24" MinHeight="24" Margin="4,0"
                                     Padding="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                                     Appearance="Secondary" Background="Transparent" BorderBrush="Transparent"
                                     Command="{Binding Path=TemplateButtonCommand, RelativeSource={RelativeSource TemplatedParent}}"
                                     Cursor="Arrow"
                                     Foreground="{DynamicResource TextControlButtonForeground}"
                                     IsTabStop="False">
                        <controls:Button.Icon>
                            <controls:SymbolIcon FontSize="{TemplateBinding FontSize}" Symbol="Dismiss24" />
                        </controls:Button.Icon>
                    </controls:Button>

                    <!--  Additional Content  -->
                    <ContentPresenter x:Name="PART_AdditionalContentHost"
                                      Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                      Margin="{StaticResource LabelTextAdditionalContentMargin}"
                                      VerticalAlignment="Center"
                                      Content="{TemplateBinding AdditionalContent}"
                                      ContentTemplate="{TemplateBinding AdditionalContentTemplate}"
                                      TextElement.FontSize="{TemplateBinding FontSize}"
                                      TextElement.Foreground="{TemplateBinding Foreground}" />
                </Grid>
            </Border>

            <!--  Accent Border (focus indicator)  -->
            <Border x:Name="AccentBorder"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="{StaticResource LabelTextAccentBorderThemeThickness}"
                    CornerRadius="{TemplateBinding Border.CornerRadius}" />
        </Grid>

        <ControlTemplate.Triggers>
            <!--  Hide label when not available  -->
            <Trigger Property="HasLabel" Value="False">
                <Setter TargetName="PART_LabelElement" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="PlaceholderTextBox" Property="Visibility" Value="Visible" />
                <Setter TargetName="PART_ContentHost" Property="Margin" Value="0" />
            </Trigger>

            <!--  Show/Hide placeholder based on CurrentPlaceholderEnabled  -->
            <Trigger Property="CurrentPlaceholderEnabled" Value="False">
                <Setter TargetName="PlaceholderTextBox" Property="Visibility" Value="Collapsed" />
            </Trigger>

            <!--  Clear button visibility  -->
            <Trigger Property="ShowClearButton" Value="False">
                <Setter TargetName="ClearButton" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="ClearButton" Property="Margin" Value="0" />
            </Trigger>

            <Trigger Property="ClearButtonEnabled" Value="False">
                <Setter TargetName="ClearButton" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="ClearButton" Property="Margin" Value="0" />
            </Trigger>

            <!--  Additional content visibility  -->
            <Trigger Property="AdditionalContent" Value="{x:Null}">
                <Setter TargetName="PART_AdditionalContentHost" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="PART_AdditionalContentHost" Property="Margin" Value="0" />
            </Trigger>

            <!--  Focus state  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsFocused" Value="True" />
                    <Condition Property="IsSimple" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="AccentBorder" Property="BorderThickness" Value="0,0,0,2" />
                <Setter TargetName="AccentBorder" Property="BorderBrush" Value="{DynamicResource TextControlFocusedBorderBrush}" />
                <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundFocused}" />
            </MultiTrigger>

            <!--  Mouse over state  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="True" />
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsFocused" Value="False" />
                    <Condition Property="IsSimple" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundPointerOver}" />
            </MultiTrigger>

            <!--  Read-only state  -->
            <Trigger Property="IsReadOnly" Value="True">
                <Setter TargetName="ClearButton" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="ClearButton" Property="Margin" Value="0" />
            </Trigger>

            <!--  Enabled state  -->
            <Trigger Property="IsEnabled" Value="True">
                <Setter Property="Cursor" Value="IBeam" />
            </Trigger>

            <!--  Disabled state  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="False" />
                    <Condition Property="IsSimple" Value="False" />
                </MultiTrigger.Conditions>
                <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource TextControlBackgroundDisabled}" />
                <Setter TargetName="ContentBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                <Setter TargetName="AccentBorder" Property="BorderBrush" Value="{DynamicResource TextControlBorderBrushDisabled}" />
                <Setter TargetName="PART_LabelElement" Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter TargetName="PART_AdditionalContentHost" Property="TextElement.Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter TargetName="PlaceholderTextBox" Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter Property="ClearButtonEnabled" Value="False" />
            </MultiTrigger>

            <!--  Disabled state (IsSimple=True) - 배경/테두리 효과 없이  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsEnabled" Value="False" />
                    <Condition Property="IsSimple" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="PART_LabelElement" Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter TargetName="PART_AdditionalContentHost" Property="TextElement.Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter TargetName="PlaceholderTextBox" Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter Property="Foreground" Value="{DynamicResource TextControlForegroundDisabled}" />
                <Setter Property="ClearButtonEnabled" Value="False" />
            </MultiTrigger>

            <Trigger Property="IsSimple" Value="True">
                <Setter TargetName="AccentBorder" Property="Visibility" Value="Collapsed" />
                <Setter TargetName="ContentBorder" Property="Background" Value="Transparent" />
                <Setter TargetName="ContentBorder" Property="BorderThickness" Value="0" />
                <Setter Property="ClearButtonEnabled" Value="False" />
                <Setter Property="MinHeight" Value="20" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!--  Default LabelText Style  -->
    <Style x:Key="DefaultLabelTextStyle" TargetType="{x:Type controls:LabelText}">
        <!--  Universal WPF UI focus  -->
        <Setter Property="FocusVisualStyle" Value="{DynamicResource DefaultControlFocusVisualStyle}" />
        <!--  Universal WPF UI ContextMenu  -->
        <Setter Property="ContextMenu" Value="{DynamicResource DefaultControlContextMenu}" />
        <!--  Text properties  -->
        <Setter Property="Foreground" Value="{DynamicResource TextControlForeground}" />
        <Setter Property="CaretBrush" Value="{DynamicResource TextControlForeground}" />
        <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextControlElevationBorderBrush}" />
        <Setter Property="BorderThickness" Value="{StaticResource LabelTextBorderThemeThickness}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="MinWidth" Value="{DynamicResource TextControlThemeMinWidth}" />
        <Setter Property="Padding" Value="{DynamicResource TextControlThemePadding}" />
        <Setter Property="Border.CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="ClearButtonEnabled" Value="True" />
        <Setter Property="LabelStyle" Value="{StaticResource DefaultLabelTextLabelStyle}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template" Value="{StaticResource DefaultLabelTextControlTemplate}" />
    </Style>

    <!--  Apply default style  -->
    <Style BasedOn="{StaticResource DefaultLabelTextStyle}" TargetType="{x:Type controls:LabelText}" />

</ResourceDictionary>
