<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:Wpf.Ui.Controls"
                    xmlns:converters="clr-namespace:Wpf.Ui.Converters">

    <!--  Converters  -->
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

    <!--  ========== Segment Resize Handle (KeyframeTimeline과 동일) ==========  -->
    <Style x:Key="MTT.SegmentHandleStyle" TargetType="Thumb">
        <Setter Property="Width" Value="4" />
        <Setter Property="Height" Value="10" />

        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Handle"
                            Background="Transparent" CornerRadius="2" Opacity="0" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Handle" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="Handle" Property="Opacity" Value="0.6" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Handle" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                            <Setter TargetName="Handle" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ========== Keyframe Thumb (원형 - 16x16 컨테이너, ScaleTransform으로 크기 조절) ==========  -->
    <!--  기본 0.625 (~10px), Hover 0.75 (~12px), Drag 1.0 (16px) - 클리핑 방지  -->
    <!--  3-Ellipse 구조: SelectedRing (선택 표시), HoverRing (호버 표시), InnerDot (메인)  -->
    <Style x:Key="MTT.KeyframeThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="-8" Y="0" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid x:Name="KeyframeGrid">
                        <!--  Hover Ring (KeyframeBrush)  -->
                        <Ellipse x:Name="HoverRing"
                                 Width="16" Height="16"
                                 Fill="{Binding KeyframeBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}, Converter={x:Static controls:WaypointBrushConverter.Instance}}"
                                 Opacity="0.3" Visibility="Hidden" />
                        <!--  Selected Ring (KeyframeSelectedBrush)  -->
                        <Ellipse x:Name="SelectedRing"
                                 Width="16" Height="16"
                                 Fill="{Binding KeyframeSelectedBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}, Converter={x:Static controls:WaypointBrushConverter.Instance}}"
                                 Opacity="0.5" Visibility="Hidden" />
                        <!--  Inner Dot (메인)  -->
                        <Ellipse x:Name="InnerDot"
                                 Width="12" Height="12"
                                 Fill="{Binding KeyframeBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}, Converter={x:Static controls:WaypointBrushConverter.Instance}}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  Hover: HoverRing 표시  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverRing" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!--  Selected: SelectedRing 표시  -->
                        <DataTrigger Binding="{Binding DataContext.IsSelected, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="SelectedRing" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ========== Waypoint Thumb (다이아몬드 - 12x12 컨테이너, ScaleTransform으로 크기 조절) ==========  -->
    <!--  기본 0.67 (~8px), Hover 0.85 (~10px), Drag 1.0 (12px) - 중심 유지됨  -->
    <Style x:Key="MTT.WaypointThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="12" />
        <Setter Property="Height" Value="12" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TransformGroup>
                    <RotateTransform Angle="45" />
                    <ScaleTransform ScaleX="0.67" ScaleY="0.67" />
                    <TranslateTransform X="-6" Y="-6" />
                </TransformGroup>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="{Binding WaypointBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}, Converter={x:Static controls:WaypointBrushConverter.Instance}}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!--  MouseOver만 (IsDragging=false): hover 스타일  -->
            <MultiTrigger>
                <MultiTrigger.Conditions>
                    <Condition Property="IsMouseOver" Value="True" />
                    <Condition Property="IsDragging" Value="False" />
                </MultiTrigger.Conditions>
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <RotateTransform Angle="45" />
                            <ScaleTransform ScaleX="0.85" ScaleY="0.85" />
                            <TranslateTransform X="-6" Y="-6" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
            </MultiTrigger>
            <!--  IsDragging: drag 스타일 (우선)  -->
            <Trigger Property="IsDragging" Value="True">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TransformGroup>
                            <RotateTransform Angle="45" />
                            <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                            <TranslateTransform X="-6" Y="-6" />
                        </TransformGroup>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!--  ========== Segment Thumb (가변 너비, ControlTemplate으로 내부 요소 정의) ==========  -->
    <!--  3-Border 구조: HoverBorder, SelectedBorder, MainBorder + Waypoints + Resize Handles  -->
    <Style x:Key="MTT.SegmentThumbStyle" TargetType="Thumb">
        <Setter Property="Height" Value="16" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="-4" />
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid x:Name="SegmentGrid" Background="Transparent">
                        <!--  Hover Border (뒤에 숨김)  -->
                        <Border x:Name="HoverBorder"
                                Height="12"
                                Background="{Binding SegmentBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}}"
                                CornerRadius="3" Opacity="0.3" Visibility="Hidden" />
                        <!--  Selected Border (뒤에 숨김)  -->
                        <Border x:Name="SelectedBorder"
                                Height="12"
                                Background="{Binding SegmentSelectedBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}}"
                                CornerRadius="3" Opacity="0.5" Visibility="Hidden" />
                        <!--  Segment Body (메인)  -->
                        <Border x:Name="MainBorder"
                                Height="8" CornerRadius="2"
                                ToolTip="{Binding TooltipText}">
                            <Border.Background>
                                <MultiBinding Converter="{x:Static controls:KeyframeSegmentBrushConverter.Instance}">
                                    <Binding Path="SegmentBrush" />
                                    <Binding Path="SegmentBrush" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                </MultiBinding>
                            </Border.Background>
                        </Border>
                        <!--  Waypoints (Segment 내부에서 직접 바인딩 - ObservableCollection 변경 반영)  -->
                        <!--  v13.8: TemplatedParent.ActualWidth 직접 바인딩으로 Canvas 위치 계산 개선  -->
                        <ItemsControl x:Name="WaypointItemsControl"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                      ItemsSource="{Binding Waypoints}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left">
                                        <Setter.Value>
                                            <MultiBinding Converter="{x:Static controls:WaypointRelativePositionConverter.Instance}">
                                                <Binding Path="RelativePosition" />
                                                <Binding Path="ActualWidth" RelativeSource="{RelativeSource AncestorType=Thumb}" />
                                            </MultiBinding>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Thumb Style="{StaticResource MTT.WaypointThumbStyle}"
                                           Tag="{Binding}"
                                           ToolTip="{Binding RelativePosition, StringFormat='Waypoint: {0:P0}'}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!--  Left Resize Handle  -->
                        <Thumb HorizontalAlignment="Left"
                               Style="{StaticResource MTT.SegmentHandleStyle}"
                               Tag="Left" />
                        <!--  Right Resize Handle  -->
                        <Thumb HorizontalAlignment="Right"
                               Style="{StaticResource MTT.SegmentHandleStyle}"
                               Tag="Right" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!--  Hover: HoverBorder 표시  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HoverBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <!--  Selected: SelectedBorder 표시 + MainBorder 좌우 축소  -->
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="SelectedBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="MainBorder" Property="Margin" Value="2,0" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ========== Scrubber Thumb ==========  -->
    <Style x:Key="MTT.ScrubberStyle" TargetType="Thumb">
        <Setter Property="Width" Value="18" />
        <Setter Property="Cursor" Value="SizeWE" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!--  Triangle Head  -->
                        <controls:SymbolIcon HorizontalAlignment="Center" VerticalAlignment="Top" Filled="True"
                                             Foreground="{Binding ScrubberBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}}"
                                             Symbol="TriangleDown20" />
                        <!--  Vertical Line  -->
                        <Rectangle Width="2" Margin="5,5,5,0"
                                   Fill="{Binding ScrubberBrush, RelativeSource={RelativeSource AncestorType=controls:MultiTrackTimeline}}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  ========== Main Control Template ==========  -->
    <Style TargetType="{x:Type controls:MultiTrackTimeline}">
        <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="TrackHeight" Value="24" />
        <Setter Property="TrackListWidth" Value="160" />
        <Setter Property="ScrubberBrush" Value="{DynamicResource PaletteRedBrush}" />
        <Setter Property="SegmentBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="SegmentSelectedBrush" Value="{DynamicResource SystemFillColorAttentionBrush}" />
        <Setter Property="KeyframeBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
        <Setter Property="KeyframeSelectedBrush" Value="{DynamicResource PaletteGreenBrush}" />
        <Setter Property="WaypointBrush" Value="{DynamicResource PaletteDeepOrangeBrush}" />
        <Setter Property="MinHeight" Value="100" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:MultiTrackTimeline}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="20" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding TrackListWidth, RelativeSource={RelativeSource TemplatedParent}}" />
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!--  ===== Row 0: Header =====  -->
                            <!--  Top-Left: Label  -->
                            <Border Grid.Row="0" Grid.Column="0"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <TextBlock Margin="8,0" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           Text="Tracks" />
                            </Border>

                            <!--  Top-Right: Time Ruler (Draggable for panning)  -->
                            <Canvas x:Name="PART_TimeRuler"
                                    Grid.Row="0" Grid.Column="2"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    ClipToBounds="True" Cursor="ScrollWE" />

                            <!--  ===== Row 1: Content =====  -->
                            <!--  Left: Track List  -->
                            <ScrollViewer x:Name="PART_TrackScrollViewer"
                                          Grid.Row="1" Grid.Column="0"
                                          Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                          HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden">
                                <ItemsControl x:Name="PART_TrackListPanel" ItemsSource="{TemplateBinding TrackGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <!--  Group Header  -->
                                                <Border Height="24"
                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                        BorderThickness="0,0,0,1" Cursor="Hand">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="16" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Path x:Name="Arrow"
                                                              Width="8" Height="8" Data="M 0,0 L 6,4 L 0,8 Z"
                                                              Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                              RenderTransformOrigin="0.5,0.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="90" />
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                   Text="{Binding Name}" />
                                                    </Grid>
                                                </Border>
                                                <!--  Tracks in Group  -->
                                                <ItemsControl ItemsSource="{Binding Tracks}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border x:Name="TrackBorder"
                                                                    Height="24" Background="Transparent"
                                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                    BorderThickness="0,0,0,1" Cursor="Hand"
                                                                    Tag="{Binding}">
                                                                <Grid Margin="16,0,4,0" Background="Transparent">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               Text="{Binding PropertyName}" />
                                                                    <!--  CurrentValue 표시 (Scrubber 위치 기준 보간값)  -->
                                                                    <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="10"
                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                               Text="{Binding CurrentValue, StringFormat={}{0:F2}}" />
                                                                </Grid>
                                                            </Border>
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter TargetName="TrackBorder" Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                                                                </DataTrigger>
                                                                <Trigger SourceName="TrackBorder" Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="TrackBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}" />
                                                                </Trigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                    <Setter TargetName="Arrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="0" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!--  Splitter  -->
                            <GridSplitter Grid.Row="1" Grid.Column="1" Width="3"
                                          HorizontalAlignment="Stretch"
                                          Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                            <!--  Right: Keyframe Area  -->
                            <Grid Grid.Row="1" Grid.Column="2">
                                <!--  Keyframe Track Canvas (with Scrubber)  -->
                                <Canvas x:Name="PART_TrackCanvas"
                                        Background="Transparent" ClipToBounds="True">
                                    <!--  Keyframe ScrollViewer 안에 트랙들 (DynamicScrollViewer로 스크롤 상태 추적)  -->
                                    <controls:DynamicScrollViewer x:Name="PART_KeyframeScrollViewer"
                                                                  Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                                                  Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                                                  HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl x:Name="PART_KeyframeItemsControl" ItemsSource="{TemplateBinding TrackGroups}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel>
                                                        <!--  Group Header Row (blank)  -->
                                                        <Border Height="24"
                                                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                BorderThickness="0,0,0,1" />
                                                        <!--  Track Keyframe Rows  -->
                                                        <ItemsControl ItemsSource="{Binding Tracks}" Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Height="24" Background="Transparent"
                                                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                            BorderThickness="0,0,0,1">
                                                                        <!--  Track Keyframe Canvas  -->
                                                                        <Canvas ClipToBounds="True" Tag="{Binding}">
                                                                            <!--  Segments (Converter 기반 위치/너비 계산 - 공유 모델 문제 해결)  -->
                                                                            <ItemsControl x:Name="PART_SegmentItemsControl"
                                                                                          Canvas.Top="8"
                                                                                          ItemsSource="{Binding Segments}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <Canvas />
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemContainerStyle>
                                                                                    <Style TargetType="ContentPresenter">
                                                                                        <Setter Property="Canvas.Left">
                                                                                            <Setter.Value>
                                                                                                <MultiBinding Converter="{x:Static controls:SegmentToCanvasConverter.Instance}" ConverterParameter="X">
                                                                                                    <Binding Path="StartTime" />
                                                                                                    <Binding Path="EndTime" />
                                                                                                    <Binding Path="ViewportStart" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                    <Binding Path="ViewportDuration" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                    <Binding Path="CanvasActualWidth" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                </MultiBinding>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Style>
                                                                                </ItemsControl.ItemContainerStyle>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <!--  MTT.SegmentThumbStyle 참조 (Tag로 Segment 바인딩)  -->
                                                                                        <Thumb Style="{StaticResource MTT.SegmentThumbStyle}" Tag="{Binding}">
                                                                                            <Thumb.Width>
                                                                                                <MultiBinding Converter="{x:Static controls:SegmentToCanvasConverter.Instance}" ConverterParameter="Width">
                                                                                                    <Binding Path="StartTime" />
                                                                                                    <Binding Path="EndTime" />
                                                                                                    <Binding Path="ViewportStart" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                    <Binding Path="ViewportDuration" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                    <Binding Path="CanvasActualWidth" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                </MultiBinding>
                                                                                            </Thumb.Width>
                                                                                        </Thumb>
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>

                                                                            <!--  Keyframes (Converter 기반 위치 계산 - Segment 중심과 정렬)  -->
                                                                            <!--  Canvas.Top="4" = Segment 중심(Y=12)과 정렬 (Keyframe Height=16, center=4+8=12)  -->
                                                                            <ItemsControl x:Name="PART_KeyframeItemsControl"
                                                                                          Canvas.Top="4"
                                                                                          ItemsSource="{Binding Keyframes}">
                                                                                <ItemsControl.ItemsPanel>
                                                                                    <ItemsPanelTemplate>
                                                                                        <Canvas />
                                                                                    </ItemsPanelTemplate>
                                                                                </ItemsControl.ItemsPanel>
                                                                                <ItemsControl.ItemContainerStyle>
                                                                                    <Style TargetType="ContentPresenter">
                                                                                        <Setter Property="Canvas.Left">
                                                                                            <Setter.Value>
                                                                                                <MultiBinding Converter="{x:Static controls:TimeToCanvasXConverter.Instance}">
                                                                                                    <Binding Path="Time" />
                                                                                                    <Binding Path="ViewportStart" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                    <Binding Path="ViewportDuration" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                    <Binding Path="CanvasActualWidth" RelativeSource="{RelativeSource AncestorType=controls:MultiTrackTimeline}" />
                                                                                                </MultiBinding>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Style>
                                                                                </ItemsControl.ItemContainerStyle>
                                                                                <ItemsControl.ItemTemplate>
                                                                                    <DataTemplate>
                                                                                        <!--  MTT.KeyframeThumbStyle 참조 (Tag로 Keyframe 바인딩)  -->
                                                                                        <Thumb Style="{StaticResource MTT.KeyframeThumbStyle}"
                                                                                               Tag="{Binding}"
                                                                                               ToolTip="{Binding Time, StringFormat='Time: {0:F2}s'}" />
                                                                                    </DataTemplate>
                                                                                </ItemsControl.ItemTemplate>
                                                                            </ItemsControl>
                                                                        </Canvas>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </controls:DynamicScrollViewer>

                                    <!--  Scrubber  -->
                                    <Thumb x:Name="PART_Scrubber"
                                           Canvas.Top="0"
                                           Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Canvas}}"
                                           Style="{StaticResource MTT.ScrubberStyle}" />
                                </Canvas>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
